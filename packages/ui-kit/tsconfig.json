{
  "extends": "../tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mf-demo/shared": [
        "../shared/dist"
      ],
      "@mf-demo/shared/*": [
        "../shared/dist/*"
      ]
    },
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*"
  ]
}
